# 이 파일을 복사해 .env 로 만들어 실제 값을 채운다.
#   cp .env.example .env
# .env 는 절대 커밋하지 않는다 (.gitignore 에 포함됨). 이 파일만 커밋한다.

# 로그 레벨 (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO

# 전송 방식: stdio(로컬/Inspector) | streamable-http(배포/PlayMCP)
# MCP_TRANSPORT=stdio

# 색상 추출은 로컬(Pillow)로 처리한다 — 외부 모델/비전 API 키가 필요 없다.

# 예) 외부 API 키 — 실제 비밀값은 여기에 두지 말고 .env 에만 둔다.
# PLAYMCP_API_KEY=
